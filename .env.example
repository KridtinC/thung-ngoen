# Copy to .env (local) and set real values. In production these are Fly.io secrets.
# NEVER commit real values — .env and .env.* are gitignored.

# MongoDB Atlas connection string (database name stays /khun-ngern)
MONGODB_URI="mongodb+srv://<user>:<pass>@<cluster>/khun-ngern?retryWrites=true&w=majority"

# AES-256-GCM key for PII (PromptPay) encryption — 32 bytes hex (64 chars).
# Must stay identical across deploys or existing encrypted data can't be decrypted.
ENCRYPTION_KEY=""

# LINE Messaging API + LIFF
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_CHANNEL_SECRET=""
LINE_LIFF_ID=""

# Cloudflare R2 (S3-compatible) for payment slip uploads
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
